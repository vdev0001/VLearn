generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String @id @default(uuid())
  name      String
  email     String @unique
  password  String

  role      Role             @default(STUDENT)
  status    ApprovalStatus   @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id                 String @id @default(uuid())
  title              String
  description        String
  youtubePlaylistUrl String
  totalVideos        Int

  instructorId       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id             String @id @default(uuid())

  studentId      String
  courseId       String
  instructorId   String

  videosWatched  Int      @default(0)
  completed      Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, courseId])
}

model Message {
  id         String @id @default(uuid())

  senderId   String
  receiverId String

  message    String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}